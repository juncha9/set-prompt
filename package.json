{
    "name": "set-prompt",
    "version": "0.0.2",
    "description": "Universal Prompt Manager for AI Coding Tools",
    "main": "dist/index.js",
    "bin": {
        "set-prompt": "./dist/index.js"
    },
    "type": "module",
    "scripts": {
        "start:dev": "tsx src/index.ts",
        "build": "tsup && npm run copy_bin && npm run copy_templates",
        "copy_bin": "cpx \"src/bin/set-prompt.js\" dist/bin",
        "copy_templates": "cpx \"src/templates/**/*\" dist/templates",
        "test": "vitest"
    },
    "keywords": [
        "prompt-manager",
        "ai-coding",
        "openclaw",
        "claude-code",
        "roo-code"
    ],
    "author": "Alkemic Studio",
    "license": "MIT",
    "dependencies": {
        "@inquirer/prompts": "^8.3.0",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "figlet": "^1.10.0",
        "fs-extra": "^11.3.3",
        "ora": "^9.3.0",
        "smol-toml": "^1.6.0",
        "typia": "^11.0.3"
    },
    "devDependencies": {
        "@types/figlet": "^1.7.0",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^25.3.0",
        "@vitest/coverage-v8": "^4.0.18",
        "cpx": "^1.5.0",
        "eslint": "^10.0.1",
        "memfs": "^4.56.11",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
