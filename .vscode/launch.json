{
    // IntelliSense를 사용하여 가능한 특성에 대해 알아보세요.
    // 기존 특성에 대한 설명을 보려면 가리킵니다.
    // 자세한 내용을 보려면 https://go.microsoft.com/fwlink/?linkid=830387을(를) 방문하세요.
    "version": "1.0.0",
    "configurations": [

        {
            "name": "start:dev",
            "command": "npm run start:dev",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}",
            "outputCapture": "std",
            "sourceMaps": true,
        },
        {
            "name": "build",
            "command": "npm run build",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}",
            "outputCapture": "console",
        },
        {
            "name": "test",
            "command": "npm run test",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}",
            "outputCapture": "console",
        },
    ]
}